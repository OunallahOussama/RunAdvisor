# Environment template for RunAdvisor
# Copy this file to .env and fill in your actual values

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_spa_client_id_here
AUTH0_AUDIENCE=https://runadvisor-api
REACT_APP_AUTH0_CALLBACK_URL=http://localhost:3000

# Strava API Credentials
STRAVA_CLIENT_ID=your_strava_client_id_here
STRAVA_CLIENT_SECRET=your_strava_client_secret_here
# OAuth scopes (frontend): activity:read_all,activity:write — users must reconnect after adding write
STRAVA_REDIRECT_URI=http://localhost:3000/callback
REACT_APP_STRAVA_REDIRECT_URI=http://localhost:3000/callback

# OpenAI API (optional, for smart weekly summaries)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Admin access — ADMIN_EMAILS alone is enough (must match Auth0/Google login email)
ADMIN_EMAILS=admin@runadvisor.fit
# Optional: only if email-based admin does not work (Google users: google-oauth2|...)
ADMIN_AUTH0_IDS=

# Strava webhooks (optional — for real-time sync)
STRAVA_WEBHOOK_VERIFY_TOKEN=your_random_verify_token
# HMAC signing secret for X-Strava-Signature (defaults to STRAVA_CLIENT_SECRET)
STRAVA_WEBHOOK_SIGNING_SECRET=
# Set to 1 in local dev only to skip signature checks when testing manually
STRAVA_WEBHOOK_SKIP_SIGNATURE=
STRAVA_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# Strava token encryption (recommended in production)
STRAVA_TOKEN_ENCRYPTION_KEY=

# CORS (comma-separated origins; production should list your site URL)
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=0

# Rate limits (optional overrides)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=60
RATE_LIMIT_STRAVA_MAX=120
RATE_LIMIT_STRAVA_WEBHOOK_MAX=120

# Usage analytics retention
USAGE_EVENT_TTL_DAYS=90

# MongoDB (already configured in docker-compose.yml)
MONGODB_URI=mongodb://admin:password@mongodb:27017/runadvisor?authSource=admin

# Application Settings
NODE_ENV=development
PORT=5000
REACT_APP_API_BASE_URL=http://localhost:5000/api
REACT_APP_AUTH0_DOMAIN=${AUTH0_DOMAIN}
REACT_APP_AUTH0_CLIENT_ID=${AUTH0_CLIENT_ID}
REACT_APP_AUTH0_AUDIENCE=${AUTH0_AUDIENCE}

# Public site / legal (optional)
REACT_APP_SITE_URL=https://runadvisor.fit
REACT_APP_CONTACT_EMAIL=support@runadvisor.fit
REACT_APP_PRIVACY_EMAIL=privacy@runadvisor.fit
REACT_APP_ADMIN_EMAILS=admin@runadvisor.fit
