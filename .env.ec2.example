# =============================================================================
# RunAdvisor — production / EC2 environment template
# =============================================================================
# Copy this file to .env.ec2 on the EC2 box, fill in the placeholders, then run
# `./scripts/deploy.sh`. NEVER commit the real .env.ec2 (it is in .gitignore).
#
# IMPORTANT: every REACT_APP_* value below is baked into the *frontend image at
# build time*. Changing any REACT_APP_* requires rebuilding the frontend image
# (`./scripts/deploy.sh` does this automatically with --build).
#
# -----------------------------------------------------------------------------
# YOU MUST FILL THESE BEFORE FIRST DEPLOY:
#   DOMAIN, LETSENCRYPT_EMAIL,
#   MONGO_INITDB_ROOT_PASSWORD (and update MONGODB_URI to match),
#   AUTH0_DOMAIN, AUTH0_CLIENT_ID, AUTH0_AUDIENCE,
#   STRAVA_CLIENT_ID, STRAVA_CLIENT_SECRET,
#   STRAVA_WEBHOOK_VERIFY_TOKEN, STRAVA_TOKEN_ENCRYPTION_KEY,
#   OPENAI_API_KEY (only if you want Smart Weekly Summary / Training Report AI),
#   ADMIN_EMAILS.
# Everything else has a safe default.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Public site (used by Caddy reverse proxy + URL substitution)
# -----------------------------------------------------------------------------
# Bare public hostname for the site. Must already point at the EC2 Elastic IP.
DOMAIN=runadvisor.example.com
# Email used by Let's Encrypt for cert expiry notifications.
LETSENCRYPT_EMAIL=ops@example.com

# -----------------------------------------------------------------------------
# MongoDB (dockerised — bound to the docker network only, NOT exposed publicly)
# -----------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change_me_strong_password
MONGO_INITDB_DATABASE=runadvisor
# Must match the credentials + db name above. Hostname is the docker service name.
MONGODB_URI=mongodb://admin:change_me_strong_password@mongodb:27017/runadvisor?authSource=admin

# -----------------------------------------------------------------------------
# Auth0
# -----------------------------------------------------------------------------
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_spa_client_id
AUTH0_AUDIENCE=https://runadvisor-api

# Auth0 Application → Settings (SPA). The values listed below must be added to
# BOTH "Allowed Callback URLs" and "Allowed Logout URLs" and "Allowed Web Origins":
#   https://${DOMAIN}
#   https://${DOMAIN}/login
#   https://www.${DOMAIN}              (only if you serve a www. variant)
#   https://www.${DOMAIN}/login        (only if you serve a www. variant)
# Logout returnTo is https://${DOMAIN}/login (see getAuth0LogoutReturnUrl).
# Enable Refresh Token Rotation + Allow Offline Access on the API.
REACT_APP_AUTH0_CALLBACK_URL=https://runadvisor.example.com

# -----------------------------------------------------------------------------
# Strava API
# -----------------------------------------------------------------------------
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
# Strava → API settings → Authorization Callback Domain: runadvisor.example.com
# (domain only, no scheme). Then the redirect URL is:
STRAVA_REDIRECT_URI=https://runadvisor.example.com/callback
REACT_APP_STRAVA_REDIRECT_URI=https://runadvisor.example.com/callback

# At-rest encryption for stored Strava access/refresh tokens.
# REQUIRED in production — generate with: openssl rand -hex 32
STRAVA_TOKEN_ENCRYPTION_KEY=

# Strava webhooks (https://${DOMAIN}/api/strava/webhook)
STRAVA_WEBHOOK_VERIFY_TOKEN=change_me_random_32_chars
# Defaults to STRAVA_CLIENT_SECRET when blank.
STRAVA_WEBHOOK_SIGNING_SECRET=
# MUST be 0 in production. Set to 1 locally to bypass HMAC verification.
STRAVA_WEBHOOK_SKIP_SIGNATURE=0
STRAVA_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# -----------------------------------------------------------------------------
# OpenAI (powers Smart Weekly Summary + Training Report)
# Leave OPENAI_API_KEY blank to fall back to deterministic non-AI summaries.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Admin access (comma-separated)
# ADMIN_EMAILS is normally enough; ADMIN_AUTH0_IDS is fallback for Google
# users where Auth0 sub is `google-oauth2|<id>` and the email is non-public.
# -----------------------------------------------------------------------------
ADMIN_EMAILS=admin@runadvisor.example.com
ADMIN_AUTH0_IDS=

# -----------------------------------------------------------------------------
# CORS, proxy, rate limits
# -----------------------------------------------------------------------------
# Comma-separated origins the API trusts (must include the public site URL).
CORS_ORIGINS=https://runadvisor.example.com,https://www.runadvisor.example.com
# Caddy sits in front of the app — trust X-Forwarded-* headers so the real
# client IP reaches the rate-limit + usage tracking middleware.
TRUST_PROXY=1

# Rate limits (safe defaults; tweak only if needed)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=60
RATE_LIMIT_STRAVA_MAX=120
RATE_LIMIT_STRAVA_WEBHOOK_MAX=120

# Usage analytics retention (UsageEvent TTL in days)
USAGE_EVENT_TTL_DAYS=90

# -----------------------------------------------------------------------------
# Backend runtime
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=5000

# -----------------------------------------------------------------------------
# Frontend build-time (baked into the bundle — rebuild on change)
# All of these MUST match the public site origin above.
# -----------------------------------------------------------------------------
REACT_APP_API_BASE_URL=https://runadvisor.example.com/api
REACT_APP_AUTH0_DOMAIN=your-tenant.us.auth0.com
REACT_APP_AUTH0_CLIENT_ID=your_auth0_spa_client_id
REACT_APP_AUTH0_AUDIENCE=https://runadvisor-api
REACT_APP_STRAVA_CLIENT_ID=your_strava_client_id

# Public site / legal copy shown in the UI footer + privacy panel.
REACT_APP_SITE_URL=https://runadvisor.example.com
REACT_APP_CONTACT_EMAIL=support@runadvisor.example.com
REACT_APP_PRIVACY_EMAIL=privacy@runadvisor.example.com
REACT_APP_ADMIN_EMAILS=admin@runadvisor.example.com
