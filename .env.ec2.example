# RunAdvisor production / EC2 environment template
# Copy to .env on the server and fill in secrets. Rebuild frontend after URL changes.

# MongoDB (docker-compose / init)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change_me
MONGO_INITDB_DATABASE=runadvisor
MONGODB_URI=mongodb://admin:change_me@mongodb:27017/runadvisor?authSource=admin

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_spa_client_id
AUTH0_AUDIENCE=https://runadvisor-api
REACT_APP_AUTH0_CALLBACK_URL=https://runadvisor.fit

# Auth0 SPA: enable Refresh Token Rotation + Allow Offline Access on the API.
# Auth0 Application → Settings (same values for Callback, Logout, and Web Origins):
#   https://runadvisor.fit
#   https://runadvisor.fit/login
#   https://www.runadvisor.fit
#   https://www.runadvisor.fit/login
#   http://runadvisor.fit
#   http://www.runadvisor.fit
#   http://localhost:3000
# Logout returnTo is https://runadvisor.fit/login (see getAuth0LogoutReturnUrl).

# Strava API
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=https://runadvisor.fit/callback
REACT_APP_STRAVA_REDIRECT_URI=https://runadvisor.fit/callback

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Admin access (comma-separated)
ADMIN_EMAILS=admin@runadvisor.fit
ADMIN_AUTH0_IDS=

# Strava webhooks (recommended in production)
STRAVA_WEBHOOK_VERIFY_TOKEN=your_random_verify_token
STRAVA_WEBHOOK_SIGNING_SECRET=
STRAVA_WEBHOOK_SKIP_SIGNATURE=
STRAVA_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# Strava token encryption (recommended: openssl rand -hex 32)
STRAVA_TOKEN_ENCRYPTION_KEY=

# CORS & proxy (behind nginx)
CORS_ORIGINS=https://runadvisor.fit,https://www.runadvisor.fit
TRUST_PROXY=1

# Rate limits (optional overrides)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=60
RATE_LIMIT_STRAVA_MAX=120
RATE_LIMIT_STRAVA_WEBHOOK_MAX=120

# Usage analytics retention
USAGE_EVENT_TTL_DAYS=90

# Application
NODE_ENV=production
PORT=5000

# Frontend build-time (must match public site origin)
REACT_APP_API_BASE_URL=https://runadvisor.fit/api
REACT_APP_AUTH0_DOMAIN=your-tenant.us.auth0.com
REACT_APP_AUTH0_CLIENT_ID=your_auth0_spa_client_id
REACT_APP_AUTH0_AUDIENCE=https://runadvisor-api
REACT_APP_STRAVA_CLIENT_ID=your_strava_client_id

# Public site / legal
REACT_APP_SITE_URL=https://runadvisor.fit
REACT_APP_CONTACT_EMAIL=support@runadvisor.fit
REACT_APP_PRIVACY_EMAIL=privacy@runadvisor.fit
REACT_APP_ADMIN_EMAILS=admin@runadvisor.fit

# Before HTTPS (certbot): use http://runadvisor.fit in every URL above, then rebuild frontend.
