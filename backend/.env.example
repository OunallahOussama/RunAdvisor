# MongoDB
# Use your running MongoDB instance here, or leave blank to use the local compose MongoDB service.
MONGODB_URI=mongodb://mongodb:27017/runadvisor

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://runadvisor-api

# Strava API
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3000/callback
# Optional: 32-byte hex key for AES-256-GCM token encryption (openssl rand -hex 32)
# STRAVA_TOKEN_ENCRYPTION_KEY=

# OpenAI (for AI recommendations)
OPENAI_API_KEY=your_openai_api_key

# Server
PORT=5000
NODE_ENV=development

# API rate limiting (optional overrides; defaults are per 15 minutes)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=300
# RATE_LIMIT_AUTH_MAX=60
# RATE_LIMIT_STRAVA_MAX=120
